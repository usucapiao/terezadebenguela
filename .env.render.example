# ============================================================
# Variáveis de ambiente — NÃO commitar este arquivo no git
# ============================================================

# ============================================================
# RENDER — variáveis que devem ser definidas no dashboard
# (Web Service → Environment) e também aqui para testes locais
# contra o banco de produção do Render.
#
# Obtenha DB_PG_URL em: PostgreSQL → Connections → Internal Database URL
# Converta o prefixo:  postgres://user:pass@host/db
#                  →   jdbc:postgresql://host/db
# ============================================================

JWT_SECRET=TROQUE_POR_STRING_LONGA_E_ALEATORIA

DB_PG_URL=TROQUE_PELA_URL_DO_BANCO_DE_DADOS_NO_RENDER
DB_PG_USERNAME=TROQUE_PELO_USUARIO_DO_RENDER
DB_PG_PASSWORD=TROQUE_PELA_SENHA_DO_RENDER

# ----------------------------
# Credenciais do painel admin
# Defina no dashboard do Render (Web Service → Environment)
# ----------------------------
ADMIN_USERNAME=TROQUE_PELO_USUARIO_ADMIN
ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE

# ----------------------------
# SMTP — notificações de candidatura de voluntário
# Deixe MAIL_HOST em branco para desabilitar o envio.
# ----------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=TROQUE_POR_APP_PASSWORD
MAIL_NOTIFICATION_RECIPIENT=destinatario@instituto.org


