# ============================================================
# Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# O arquivo .env NUNCA deve ser commitado no git
# ============================================================

# H2 Database (desenvolvimento local)
DB_H2_URL=jdbc:h2:file:./data/teresadb;DB_CLOSE_DELAY=-1
DB_H2_USERNAME=sa
DB_H2_PASSWORD=

# PostgreSQL
DB_PG_URL=jdbc:postgresql://localhost:5432/teresadb
DB_PG_USERNAME=SEU_USUARIO_POSTGRES
DB_PG_PASSWORD=SUA_SENHA_POSTGRES

# JWT Secret — use uma string longa e aleatória em produção
# Gere com: openssl rand -hex 32
# JWT_SECRET=TROQUE_POR_UMA_STRING_SECRETA_LONGA
