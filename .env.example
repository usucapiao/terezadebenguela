# ================================================================
# Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env — ele contém segredos.
# ================================================================

# ----------------------------
# H2 Database (desenvolvimento local)
# ----------------------------
DB_H2_URL=jdbc:h2:file:./data/teresadb;DB_CLOSE_DELAY=-1
DB_H2_USERNAME=sa
DB_H2_PASSWORD=

# ----------------------------
# JWT (backend Spring Boot)
# ----------------------------
# Use uma string longa e aleatória (mínimo 32 chars).
# Gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_POR_UMA_STRING_SECRETA_LONGA

# ----------------------------
# PostgreSQL — conexão da aplicação Spring Boot
# Em ambiente Docker, o host é "db" (nome do serviço no docker-compose.yml)
# Em desenvolvimento local, use "localhost"
# ----------------------------
DB_PG_URL=jdbc:postgresql://db:5432/teresadb
DB_PG_USERNAME=teresa
DB_PG_PASSWORD=TROQUE_POR_SENHA_FORTE

# ----------------------------
# PostgreSQL — configuração interna do container
# Deve ser idêntica aos valores DB_PG_* acima
# ----------------------------
POSTGRES_DB=teresadb
POSTGRES_USER=teresa
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# ----------------------------
# Credenciais do painel admin
# Defina um usuário e senha fortes — estes valores são usados
# apenas na primeira inicialização (quando o banco está vazio).
# ----------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE

# ----------------------------
# SMTP — notificações de candidatura de voluntário
# Deixe MAIL_HOST em branco para desabilitar o envio.
# Exemplo com Gmail: host=smtp.gmail.com, port=587, use App Password.
# ----------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=TROQUE_POR_APP_PASSWORD
MAIL_NOTIFICATION_RECIPIENT=destinatario@instituto.org
